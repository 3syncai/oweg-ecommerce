# Medusa Backend URL
# Production: https://participate-rap-kodak-whats.trycloudflare.com
# Development: http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://participate-rap-kodak-whats.trycloudflare.com

# Medusa Publishable Key (optional but recommended)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Backend Server-Side Secrets
# Note: These are only accessible in Next.js server-side code (API routes, server components)
# They are NOT accessible in client-side browser code
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Debug controller (vendor portal protections + /debug-controller-4719)
# REQUIRED on Vercel for vendor.0weg.in — settings are persisted in Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa
DEBUG_CONTROLLER_SECRET=oweg-debug-4719-change-me

# Production (Vercel vendor-portal project):
# 1. DATABASE_URL — same RDS URL as Medusa/storefront (with ?sslmode=require if needed)
# 2. DEBUG_CONTROLLER_SECRET — secret you enter on /debug-controller-4719
# 3. NEXT_PUBLIC_MEDUSA_BACKEND_URL — your live Medusa API URL (not localhost)