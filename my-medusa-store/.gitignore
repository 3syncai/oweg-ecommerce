# Medusa backend ignores

# Node dependencies
node_modules/

# Build outputs
dist/
build/
.cache/
.turbo/
.swc/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/Editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Env and secrets (keep only examples)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.template
.env.test
*.env
!.env.example
!.env.local.example
!*example*

# Database/cache/temp
tmp/
temp/
.tmp/
*.sqlite
*.db
*.sql
dump.rdb
uploads/
storage/

# The `uploads/` pattern above is meant for runtime user-uploaded files,
# but it also matches our source-code route directory at
# src/api/store/vendor/uploads/ — which has to be committed and deployed,
# otherwise the vendor-signup form gets 404 on POST /store/vendor/uploads.
# Whitelist that specific source path back in.
!src/api/store/vendor/uploads/
!src/api/store/vendor/uploads/**

# Misc
coverage/
.nyc_output/
.vercel/
yarn.lock
my-medusa-store/yarn.lock
my-medusa-store/.medusa/
.medusa/
