{
    "rewrites": [
        {
            "source": "/admin/:path*",
            "destination": "https://api.oweg.itshover.com/admin/:path*"
        },
        {
            "source": "/store/:path*",
            "destination": "https://api.oweg.itshover.com/store/:path*"
        },
        {
            "source": "/auth/:path*",
            "destination": "https://api.oweg.itshover.com/auth/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://api.oweg.itshover.com/:path*"
        },
        {
            "source": "/app/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/app",
            "destination": "/index.html"
        },
        {
            "source": "/app/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}