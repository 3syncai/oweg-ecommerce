# OWEG Storefront — environment variables
# Copy to `.env.local` for local development. Set all required values in Vercel for production.
# Never commit real secrets to git.

# -----------------------------------------------------------------------------
# App / URLs
# -----------------------------------------------------------------------------
# Public storefront URL (used for server-to-server callbacks when VERCEL_URL is unset)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canonical site URL for Razorpay callbacks (optional; falls back to VERCEL_URL)
# NEXT_PUBLIC_SITE_URL=https://oweg-ecommerce.vercel.app

# Payment redirect paths (relative to storefront origin)
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=/order/success
NEXT_PUBLIC_PAYMENT_FAILED_URL=/order/failed

# -----------------------------------------------------------------------------
# Medusa (store API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Optional Medusa IDs (resolved automatically when omitted in dev)
# NEXT_PUBLIC_MEDUSA_SALES_CHANNEL_ID=
# NEXT_PUBLIC_MEDUSA_REGION_ID=
# MEDUSA_DEFAULT_SHIPPING_OPTION_ID=

# Admin API (server-only — never expose to the browser)
MEDUSA_ADMIN_API_KEY=
MEDUSA_ADMIN_AUTH_SCHEME=bearer

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oweg_db

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Security secrets (use strong random values in production — openssl rand -hex 32)
# -----------------------------------------------------------------------------

# Debug controller dashboard (/debug-controller-4719) — REQUIRED in production
DEBUG_CONTROLLER_SECRET=

# Server-to-server wallet mutation auth (must match Medusa INTERNAL_API_SECRET)
INTERNAL_API_SECRET=

# Cron job auth for POST /api/cron/expire-coins (Authorization: Bearer <secret>)
CRON_SECRET=

# Medusa → storefront webhooks (order-delivered, order-cancelled)
# Header: x-webhook-secret
MEDUSA_WEBHOOK_SECRET=

# Legacy alias accepted by debug-controller auth (prefer DEBUG_CONTROLLER_SECRET)
# DEBUG_CONTROLLER_TOKEN=

# Set to "true" to emit Content-Security-Policy-Report-Only instead of enforcing CSP
# CSP_REPORT_ONLY=false

# -----------------------------------------------------------------------------
# Search (OpenSearch)
# -----------------------------------------------------------------------------
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASS=
# OPENSEARCH_PRODUCTS_INDEX=products

# -----------------------------------------------------------------------------
# Affiliate / integrations
# -----------------------------------------------------------------------------
# AFFILIATE_WEBHOOK_URL=

# Optional tunnel host for ngrok / Cloudflare when testing on a phone (dev only).
# Example: evasive-laverne-semipaganish.ngrok-free.dev
# DEV_TUNNEL_HOST=

# -----------------------------------------------------------------------------
# Optional UI
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# NEXT_PUBLIC_WHATSAPP_MESSAGE=

# -----------------------------------------------------------------------------
# Medusa backend secrets (set on the Medusa host, not only Vercel storefront)
# -----------------------------------------------------------------------------
# JWT_SECRET=           # Medusa auth tokens — strong random, never "supersecret" in prod
# COOKIE_SECRET=        # Medusa session cookies — strong random, never "supersecret" in prod
# STORE_CORS=
# ADMIN_CORS=
# AUTH_CORS=
